<UserControl x:Class="TwitchChatOverlay.Views.Tabs.YouTubeSettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{StaticResource BackgroundBrush}"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:actions="clr-namespace:TwitchChatOverlay.Behaviours">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <actions:LoadedEventBehaviour />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12,12,12" VerticalAlignment="Top">
            <TextBlock Text="YouTube 設定"
                       FontSize="18" FontWeight="Bold"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock Text="🔴 YouTube 認可"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,8"
                       Foreground="#FF3B30"/>

            <Border Background="#2A1A1A"
                    BorderBrush="#FF3B30"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{Binding YouTubeTokenInfo}"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                    <TextBlock Text="この機能は YouTube API Services を使用し、YouTube Live Chat の読み取り専用権限のみを要求します。取得したアクセストークンとリフレッシュトークンは Windows の保護機能を使ってローカル保存されます。"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap"
                           FontSize="11"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Grid.Column="0"
                        Content="プライバシーポリシー"
                        Command="{Binding OpenPrivacyPolicyCommand}"
                    Height="36"
                        Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Content="利用条件"
                        Command="{Binding OpenTermsOfUseCommand}"
                    Height="36"
                        Margin="0,0,0,8"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="0"
                        Content="YouTube 利用規約"
                        Command="{Binding OpenYouTubeTermsCommand}"
                    Height="36"
                        Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="1"
                        Content="Google Privacy"
                        Command="{Binding OpenGooglePrivacyPolicyCommand}"
                    Height="36"
                        Margin="0,0,0,8"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Row="2" Grid.Column="0"
                        Content="権限管理"
                        Command="{Binding OpenGooglePermissionsCommand}"
                    Height="36"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding YouTubeLegalConsentAccepted}"
                              VerticalAlignment="Top"
                              Margin="0,2,8,0"/>
                    <TextBlock Grid.Column="1"
                               Text="プライバシーポリシー、利用条件、YouTube 利用規約を確認し、YouTube API Services の利用に同意します"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </Grid>

            <Button Content="🌐 YouTubeで認可する"
                    Command="{Binding AuthorizeYouTubeOAuthCommand}"
                    Height="38"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,0,8"/>

                <TextBlock Text="YouTube コンテンツとデータの提供元は YouTube です。保存済みデータの削除後も、Google アカウント側の権限は別途取り消しが必要になる場合があります。"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Margin="0,0,0,8"/>

            <Separator Margin="0,12,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="📡 接続"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,8"
                       Foreground="#FF3B30"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <Button Content="▶ 接続"
                        Command="{Binding ConnectYouTubeCommand}"
                        Width="90" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="⏹ 切断"
                        Command="{Binding DisconnectYouTubeCommand}"
                        Width="90" Height="36"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>

            <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="🔔 通知設定"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="#FF3B30"/>

            <WrapPanel Margin="0,0,0,4">
                <CheckBox Content="💬 コメント" IsChecked="{Binding ShowYouTubeChat}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="💸 Super Chat" IsChecked="{Binding ShowYouTubeSuperChat}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="🌟 メンバーシップ" IsChecked="{Binding ShowYouTubeMembership}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
            </WrapPanel>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="重複抑止キャッシュ件数"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding YouTubeMessageCacheSize, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock Grid.Column="2"
                           Text="100以上。再接続時の旧コメント抑止に使います。多いほど再表示を防ぎやすいですが、保持メモリは増えます。"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>

                <Button Content="💬 YouTube コメントをプレビュー"
                    Command="{Binding PreviewYouTubeCommentCommand}"
                    Height="34"
                    Margin="0,8,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"/>

            <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

        <TextBlock Text="🧹 認可の削除と取り消し"
               FontSize="13" FontWeight="Bold"
               Margin="0,0,0,10"
               Foreground="#FF3B30"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Grid.Column="0"
                        Content="ローカル保存データを削除"
                        Command="{Binding ClearYouTubeAuthorizationCommand}"
                    Height="38"
                        Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Content="Google 権限を取り消して削除"
                        Command="{Binding RevokeYouTubeAuthorizationCommand}"
                    Height="38"
                        Margin="0,0,0,8"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="0"
                        Content="サポート窓口"
                        Command="{Binding OpenSupportCommand}"
                    Height="38"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>

        <TextBlock Text="ローカル削除はこの PC に保存されたトークンのみ削除します。Google 側のアクセス権も止める場合は、権限取り消し操作または Google 権限管理ページを使用してください。"
               Foreground="{StaticResource TextSecondaryBrush}"
               TextWrapping="Wrap"
               FontSize="11"
               Margin="0,0,0,8"/>

        <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="🎬 OBS 連携"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="#FF3B30"/>

            <CheckBox Content="OBS WebSocket 連携を有効化"
                      IsChecked="{Binding ObsWebSocketEnabled}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Host"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ObsWebSocketHost}"
                         IsEnabled="{Binding ObsWebSocketEnabled}"/>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Port"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ObsWebSocketPort}"
                         IsEnabled="{Binding ObsWebSocketEnabled}"/>
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Password"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="ObsPasswordBox"
                             Grid.Column="1"
                             IsEnabled="{Binding ObsWebSocketEnabled}"
                         Text="{Binding ObsWebSocketPassword}"
                             />
            </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="▶ OBS接続"
                    Command="{Binding ConnectObsCommand}"
                    Width="110" Height="36"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,8,0"/>
                <Button Content="⏹ OBS切断"
                    Command="{Binding DisconnectObsCommand}"
                    Width="110" Height="36"
                    Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>

                <TextBlock Text="{Binding ObsStatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,8,0,0"/>

                <TextBlock Text="OBS 連携を使う場合は、YouTube 接続の前にここで OBS へ接続してください。OBS 未接続時は YouTube 側で即時確認にフォールバックします。"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Margin="0,6,0,0"/>

            <TextBlock Text="{Binding YouTubeStatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
