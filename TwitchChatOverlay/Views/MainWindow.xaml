<Window x:Class="TwitchChatOverlay.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="Twitch Chat Overlay"
        Height="760"
        Width="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- 更新通知バナー -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2D6A2D"
                Padding="16,10"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LatestVersion, StringFormat='🆕 新しいバージョン {0} があります'}"
                               Foreground="#FFFFFF"
                               FontSize="13" FontWeight="Bold"/>
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding UpdateProgressPercent}"
                                 Height="4" Margin="0,4,0,0"
                                 Foreground="#4CAF50"
                                 Background="#1A4A1A"
                                 Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔗 リリースページ"
                        Command="{Binding OpenReleasePageCommand}"
                        Height="30"
                        Padding="10,0"
                        Margin="8,0,0,0"
                        FontSize="12"
                        Background="#1A4A1A"
                        Foreground="#CCFFCC"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        Cursor="Hand"/>

                <Button Grid.Column="2"
                        Content="⬇ 更新する"
                        Command="{Binding UpdateCommand}"
                        Height="30"
                        Padding="14,0"
                        Margin="8,0,0,0"
                        FontSize="12"
                        Background="#4CAF50"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#2D4A2D"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#66BB6A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20" VerticalAlignment="Top">

                <TextBlock Text="Twitch Chat Overlay"
                           FontSize="20" FontWeight="Bold"
                           Margin="0,0,0,20"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Twitch認可 -->
                <TextBlock Text="🔑 Twitch 認可"
                           FontSize="13" FontWeight="Bold"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource TwitchPurpleBrush}"/>

                <!-- 保存済みトークン情報 -->
                <Border Background="#1A1A2E"
                        BorderBrush="#9146FF"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        Visibility="{Binding HasToken, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding TokenInfo}"
                               Foreground="#CCCCCC"
                               FontSize="12"/>
                </Border>

                <Button Content="🌐 Twitchで認可する"
                        Command="{Binding AuthorizeOAuthCommand}"
                        Height="38"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,8"/>

                <!-- Device Auth コード表示 -->
                <Border Visibility="{Binding IsAuthorizingOAuth, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="#1A2A1A"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="ブラウザでTwitchの認可ページが開きました。以下のコードを入力してください："
                                   Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding DeviceUserCode}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#4CAF50"
                                   HorizontalAlignment="Center"
                                   FontFamily="Consolas"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="認可待機中..."
                                   Foreground="#666666" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Separator Margin="0,12,0,12" Background="{StaticResource BorderBrush}"/>

                <!-- チャンネル接続 -->
                <TextBlock Text="📡 接続"
                           FontSize="13" FontWeight="Bold"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource TwitchPurpleBrush}"/>

                <TextBlock Text="チャンネル名"
                           Margin="0,0,0,4"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12"/>
                <TextBox Text="{Binding ChannelName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource StandardTextBoxStyle}"
                         Margin="0,0,0,6"
                         ToolTip="例: pokimane, ninja"/>

                <!-- 接続履歴 -->
                <ItemsControl ItemsSource="{Binding RecentChannels}"
                              Margin="0,0,0,10"
                              Visibility="{Binding HasRecentChannels, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Command="{Binding DataContext.SelectRecentChannelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="2,1"
                                    Cursor="Hand"
                                    FontSize="12"
                                    Foreground="{StaticResource TwitchPurpleBrush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <Button Content="▶ 接続"
                            Command="{Binding ConnectCommand}"
                            Width="90" Height="36"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="⏹ 切断"
                            Command="{Binding DisconnectCommand}"
                            Width="90" Height="36"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>

                <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

                <!-- 通知設定 -->
                <TextBlock Text="🔔 通知設定"
                           FontSize="13" FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource TwitchPurpleBrush}"/>

                <WrapPanel Margin="0,0,0,4">
                    <CheckBox Content="🎁 チャンネルポイント" IsChecked="{Binding ShowReward}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="⚔️ レイド" IsChecked="{Binding ShowRaid}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="❤️ フォロー" IsChecked="{Binding ShowFollow}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="⭐ サブスク" IsChecked="{Binding ShowSubscribe}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="🎁 ギフトサブ" IsChecked="{Binding ShowGiftSubscribe}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="🔄 リサブ" IsChecked="{Binding ShowResub}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="🚂 ハイプトレイン開始" IsChecked="{Binding ShowHypeTrainBegin}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                    <CheckBox Content="🏁 ハイプトレイン終了" IsChecked="{Binding ShowHypeTrainEnd}"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                </WrapPanel>

                <Separator Margin="0,8,0,12" Background="{StaticResource BorderBrush}"/>

                <!-- トースト設定 -->
                <TextBlock Text="⏱ トースト設定"
                           FontSize="13" FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource TwitchPurpleBrush}"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="表示時間 (秒)"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <Slider Grid.Column="1" Minimum="1" Maximum="30"
                            Value="{Binding ToastDurationSeconds}"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                    <TextBlock Grid.Column="2" Text="{Binding ToastDurationSeconds}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="3"/>
                    <TextBlock Grid.Column="4" Text="最大同時表示"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <Slider Grid.Column="5" Minimum="1" Maximum="10"
                            Value="{Binding ToastMaxCount}"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                    <TextBlock Grid.Column="6" Text="{Binding ToastMaxCount}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="4,0,0,0"/>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="表示位置"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="1" SelectedIndex="{Binding ToastPositionIndex}" Height="28" FontSize="12">
                        <ComboBoxItem Content="右上"/>
                        <ComboBoxItem Content="左上"/>
                        <ComboBoxItem Content="右下"/>
                        <ComboBoxItem Content="左下"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="モニター"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding MonitorList}"
                              SelectedIndex="{Binding ToastMonitorIndex}"
                              Height="28" FontSize="12"/>
                </Grid>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="文字サイズ"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <Slider Grid.Column="1"
                            Minimum="8" Maximum="24"
                            Value="{Binding ToastFontSize}"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding ToastFontSize, StringFormat={}{0:F0}, UpdateSourceTrigger=LostFocus}"
                             Height="24" Margin="4,0,0,0"
                             VerticalContentAlignment="Center"
                             TextAlignment="Right" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="pt"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="2,0,0,0"/>
                </Grid>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="横幅"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <Slider Grid.Column="1"
                            Minimum="200" Maximum="600"
                            Value="{Binding ToastWidth}"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="True" TickFrequency="20"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding ToastWidth, StringFormat={}{0:F0}, UpdateSourceTrigger=LostFocus}"
                             Height="24" Margin="4,0,0,0"
                             VerticalContentAlignment="Center"
                             TextAlignment="Right" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="px"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="2,0,0,0"/>
                </Grid>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="背景の濃さ"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <Slider Grid.Column="1"
                            Minimum="0" Maximum="100"
                            Value="{Binding ToastBackgroundOpacityPercent}"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="True" TickFrequency="5"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding ToastBackgroundOpacityPercent, UpdateSourceTrigger=LostFocus}"
                             Height="24" Margin="4,0,0,0"
                             VerticalContentAlignment="Center"
                             TextAlignment="Right" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="%"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="2,0,0,0"/>
                </Grid>

                <!-- フォント指定 -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="フォント"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="1"
                              IsEditable="True"
                              Text="{Binding ToastFontFamily, UpdateSourceTrigger=LostFocus}"
                              ItemsSource="{Binding FontFamilyPresets}"
                              Height="28" FontSize="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="">
                                                    <Setter Property="Text" Value="(デフォルト)"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- 背景色モード -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="背景色"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="1"
                              SelectedIndex="{Binding ToastBackgroundModeIndex}"
                              Height="28" FontSize="12">
                        <ComboBoxItem Content="ダーク"/>
                        <ComboBoxItem Content="ライト"/>
                        <ComboBoxItem Content="システム設定"/>
                        <ComboBoxItem Content="カスタム"/>
                    </ComboBox>
                </Grid>

                <!-- カスタム色入力 (カスタム選択時のみ表示) -->
                <Grid Margin="0,6,0,0"
                      Visibility="{Binding IsCustomBackgroundColor, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text=""
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ToastCustomBackgroundColor, UpdateSourceTrigger=LostFocus}"
                             Height="28" VerticalContentAlignment="Center"
                             FontSize="12" FontFamily="Consolas"
                             ToolTip="#RRGGBB 形式で入力 (例: #1A1A2E)"/>
                    <TextBlock Grid.Column="2"
                               Text="  HEX (#RRGGBB)"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                </Grid>

                <!-- フォント色モード -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="文字色"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="1"
                              SelectedIndex="{Binding ToastFontColorModeIndex}"
                              Height="28" FontSize="12">
                        <ComboBoxItem Content="自動（背景色に合わせる）"/>
                        <ComboBoxItem Content="カスタム"/>
                    </ComboBox>
                </Grid>

                <!-- カスタムフォント色入力 (カスタム選択時のみ表示) -->
                <Grid Margin="0,6,0,0"
                      Visibility="{Binding IsCustomFontColor, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text=""
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ToastCustomFontColor, UpdateSourceTrigger=LostFocus}"
                             Height="28" VerticalContentAlignment="Center"
                             FontSize="12" FontFamily="Consolas"
                             ToolTip="#RRGGBB 形式で入力 (例: #FFFFFF)"/>
                    <TextBlock Grid.Column="2"
                               Text="  HEX (#RRGGBB)"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                </Grid>

                <Separator Margin="0,14,0,12" Background="{StaticResource BorderBrush}"/>

                <Button Content="💾 設定を保存"
                        Command="{Binding SaveSettingsCommand}"
                        Width="130" Height="36"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SuccessButtonStyle}"
                        Margin="0,0,0,12"/>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           FontSize="12"/>

                <ProgressBar Height="3"
                             Margin="0,6,0,0"
                             Background="{StaticResource BorderBrush}"
                             Foreground="{StaticResource TwitchPurpleBrush}"
                             Visibility="{Binding IsAuthorizingOAuth, Converter={StaticResource BooleanToVisibilityConverter}}"
                             IsIndeterminate="True"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>