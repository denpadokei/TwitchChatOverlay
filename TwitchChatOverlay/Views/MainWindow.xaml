<Window x:Class="TwitchChatOverlay.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:tabs="clr-namespace:TwitchChatOverlay.Views.Tabs"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="Twitch Chat Overlay"
        Height="760"
        Width="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- 更新通知バナー -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2D6A2D"
                Padding="16,10"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LatestVersion, StringFormat='🆕 新しいバージョン {0} があります'}"
                               Foreground="#FFFFFF"
                               FontSize="13" FontWeight="Bold"/>
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding UpdateProgressPercent}"
                                 Height="4" Margin="0,4,0,0"
                                 Foreground="#4CAF50"
                                 Background="#1A4A1A"
                                 Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔗 リリースページ"
                        Command="{Binding OpenReleasePageCommand}"
                        Height="30"
                        Padding="10,0"
                        Margin="8,0,0,0"
                        FontSize="12"
                        Background="#1A4A1A"
                        Foreground="#CCFFCC"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        Cursor="Hand"/>

                <Button Grid.Column="2"
                        Content="⬇ 更新する"
                        Command="{Binding UpdateCommand}"
                        Height="30"
                        Padding="14,0"
                        Margin="8,0,0,0"
                        FontSize="12"
                        Background="#4CAF50"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#2D4A2D"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#66BB6A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="16,14,16,14"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="共通">
                <tabs:CommonSettingsTabView />
            </TabItem>
            <TabItem Header="Twitch">
                <tabs:TwitchSettingsTabView />
            </TabItem>
            <TabItem Header="YouTube">
                <tabs:YouTubeSettingsTabView />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Margin="16,0,16,14"
                Padding="0,8,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource BackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="💾 設定を保存"
                        Command="{Binding SaveSettingsCommand}"
                        Width="130"
                        Height="36"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SuccessButtonStyle}"/>

                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>