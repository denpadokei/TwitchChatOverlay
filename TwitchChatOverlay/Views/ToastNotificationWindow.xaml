<Window x:Class="TwitchChatOverlay.Views.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TwitchChatOverlay.Models"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        Title="ToastNotification" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Opacity="0">
    <Window.Resources>
        <!-- テキストフラグメント -->
        <DataTemplate DataType="{x:Type models:TextFragment}">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding DataContext.TextForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                       FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                       FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
        </DataTemplate>
        <!-- 静止エモート -->
        <DataTemplate DataType="{x:Type models:StaticEmoteFragment}">
            <Image Source="{Binding EmoteUrl}"
                   Width="22" Height="22"
                   Margin="1,0"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </DataTemplate>
        <!-- アニメーションエモート -->
        <DataTemplate DataType="{x:Type models:AnimatedEmoteFragment}">
            <Image gif:AnimationBehavior.SourceUri="{Binding EmoteUrl}"
                   gif:AnimationBehavior.RepeatBehavior="Forever"
                   Width="22" Height="22"
                   Margin="1,0"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </DataTemplate>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="8"
            Margin="5"
            Background="{Binding BackgroundBrush}"
            Effect="{x:Null}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- カラーバー -->
            <Border Grid.Column="0"
                    Background="{Binding ThemeColorBrush}"
                    CornerRadius="8,0,0,8"/>

            <!-- コンテンツ -->
            <StackPanel Grid.Column="1" Margin="10,10,10,10"
                        TextElement.FontFamily="{Binding FontFamily}">
                <!-- タイプアイコン + ユーザー名 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TypeIcon}"
                               FontSize="{Binding UsernameFontSize}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Username}"
                               FontWeight="Bold"
                               FontSize="{Binding UsernameFontSize}"
                               Foreground="{Binding UserColorBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="260"/>
                </StackPanel>

                <!-- メインテキスト (エモート付きチャット) -->
                <ItemsControl ItemsSource="{Binding Fragments}"
                              Margin="0,4,0,0"
                              Visibility="{Binding HasFragments, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- メインテキスト (プレーンテキスト) -->
                <TextBlock Text="{Binding DisplayText}"
                           Foreground="{Binding TextForegroundBrush}"
                           FontSize="{Binding FontSize}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"
                           Visibility="{Binding NoFragments, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- サブテキスト（オプション） -->
                <TextBlock Text="{Binding SubText}"
                           Foreground="{Binding SubTextForegroundBrush}"
                           FontSize="{Binding SubTextFontSize}"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0"
                           Visibility="{Binding HasSubText, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
