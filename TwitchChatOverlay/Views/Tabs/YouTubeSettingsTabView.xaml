<UserControl x:Class="TwitchChatOverlay.Views.Tabs.YouTubeSettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:action="clr-namespace:TwitchChatOverlay.Behaviours"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{StaticResource BackgroundBrush}"
             Loaded="OnLoaded">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <action:LoadedEventBehaviour />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12,12,12" VerticalAlignment="Top">
            <TextBlock Text="YouTube 設定"
                       FontSize="18" FontWeight="Bold"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock Text="🔴 YouTube 認可"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,8"
                       Foreground="#FF3B30"/>

            <Border Background="#2A1A1A"
                    BorderBrush="#FF3B30"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,8">
                <TextBlock Text="{Binding YouTubeTokenInfo}"
                           Foreground="#CCCCCC"
                           FontSize="12"/>
            </Border>

            <Button Content="🌐 YouTubeで認可する"
                    Command="{Binding AuthorizeYouTubeOAuthCommand}"
                    Height="38"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,0,8"/>

            <Separator Margin="0,12,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="📡 接続"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,8"
                       Foreground="#FF3B30"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <Button Content="▶ 接続"
                        Command="{Binding ConnectYouTubeCommand}"
                        Width="90" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="⏹ 切断"
                        Command="{Binding DisconnectYouTubeCommand}"
                        Width="90" Height="36"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>

            <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="🔔 通知設定"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="#FF3B30"/>

            <WrapPanel Margin="0,0,0,4">
                <CheckBox Content="💬 コメント" IsChecked="{Binding ShowYouTubeChat}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="💸 Super Chat" IsChecked="{Binding ShowYouTubeSuperChat}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="🌟 メンバーシップ" IsChecked="{Binding ShowYouTubeMembership}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
            </WrapPanel>

                <Button Content="💬 YouTube コメントをプレビュー"
                    Command="{Binding PreviewYouTubeCommentCommand}"
                    Height="34"
                    Margin="0,8,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"/>

            <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="🎬 OBS 連携"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="#FF3B30"/>

            <CheckBox Content="OBS WebSocket 連携を有効化"
                      IsChecked="{Binding ObsWebSocketEnabled}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Host"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ObsWebSocketHost}"
                         IsEnabled="{Binding ObsWebSocketEnabled}"/>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Port"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ObsWebSocketPort}"
                         IsEnabled="{Binding ObsWebSocketEnabled}"/>
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Password"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <PasswordBox x:Name="ObsPasswordBox"
                             Grid.Column="1"
                             Style="{StaticResource StandardPasswordBoxStyle}"
                             IsEnabled="{Binding ObsWebSocketEnabled}"
                             PasswordChanged="OnObsPasswordChanged"/>
            </Grid>

            <TextBlock Text="OBS未利用時は接続時に1回だけ即時確認し、その後30秒間隔で配信確認します。"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Margin="0,2,0,0"/>

            <TextBlock Text="{Binding YouTubeStatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
