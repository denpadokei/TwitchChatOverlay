<UserControl x:Class="TwitchChatOverlay.Views.Tabs.TwitchSettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12,12,12" VerticalAlignment="Top">
            <TextBlock Text="Twitch 設定"
                       FontSize="18" FontWeight="Bold"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock Text="🔑 Twitch 認可"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,8"
                       Foreground="{StaticResource TwitchPurpleBrush}"/>

            <Border Background="#1A1A2E"
                    BorderBrush="#9146FF"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding HasToken, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding TokenInfo}"
                           Foreground="#CCCCCC"
                           FontSize="12"/>
            </Border>

            <Button Content="🌐 Twitchで認可する"
                    Command="{Binding AuthorizeOAuthCommand}"
                    Height="38"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,0,8"/>

            <Border Visibility="{Binding IsAuthorizingOAuth, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="#1A2A1A"
                    BorderBrush="#4CAF50"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ブラウザでTwitchの認可ページが開きました。以下のコードを入力してください："
                               Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DeviceUserCode}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#4CAF50"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="認可待機中..."
                               Foreground="#666666" FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Separator Margin="0,12,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="📡 接続"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,8"
                       Foreground="{StaticResource TwitchPurpleBrush}"/>

            <TextBlock Text="チャンネル名"
                       Margin="0,0,0,4"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="12"/>
            <TextBox Text="{Binding ChannelName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource StandardTextBoxStyle}"
                     Margin="0,0,0,6"
                     ToolTip="例: pokimane, ninja"/>

            <ItemsControl ItemsSource="{Binding RecentChannels}"
                          Margin="0,0,0,10"
                          Visibility="{Binding HasRecentChannels, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}"
                                Command="{Binding DataContext.SelectRecentChannelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="2,1"
                                Cursor="Hand"
                                FontSize="12"
                                Foreground="{StaticResource TwitchPurpleBrush}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <Button Content="▶ 接続"
                        Command="{Binding ConnectCommand}"
                        Width="90" Height="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="⏹ 切断"
                        Command="{Binding DisconnectCommand}"
                        Width="90" Height="36"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>

            <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

            <TextBlock Text="🔔 通知設定"
                       FontSize="13" FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="{StaticResource TwitchPurpleBrush}"/>

            <WrapPanel Margin="0,0,0,4">
                <CheckBox Content="🎁 チャンネルポイント" IsChecked="{Binding ShowReward}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="⚔️ レイド" IsChecked="{Binding ShowRaid}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="❤️ フォロー" IsChecked="{Binding ShowFollow}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="⭐ サブスク" IsChecked="{Binding ShowSubscribe}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="🎁 ギフトサブ" IsChecked="{Binding ShowGiftSubscribe}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="🔄 リサブ" IsChecked="{Binding ShowResub}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="🚂 ハイプトレイン開始" IsChecked="{Binding ShowHypeTrainBegin}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
                <CheckBox Content="🏁 ハイプトレイン終了" IsChecked="{Binding ShowHypeTrainEnd}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,16,8"/>
            </WrapPanel>

            <ProgressBar Height="3"
                         Margin="0,6,0,0"
                         Background="{StaticResource BorderBrush}"
                         Foreground="{StaticResource TwitchPurpleBrush}"
                         Visibility="{Binding IsAuthorizingOAuth, Converter={StaticResource BooleanToVisibilityConverter}}"
                         IsIndeterminate="True"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
